{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:main",
      "type": "npm",
      "script": "build:main",
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "dev:renderer",
      "type": "npm",
      "script": "dev:renderer",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
