{
  "name": "teams-chat-notifier",
  "version": "1.0.1",
  "description": "Monitor Microsoft Teams chats across multiple tenants with native notifications",
  "main": "dist/main/main/index.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/main/index.js http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist:mac": "electron-builder --mac --config electron-builder.config.ts",
    "dist:win": "electron-builder --win --config electron-builder.config.ts",
    "lint": "eslint src tests --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.main.ts",
    "test:component": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.main.ts --coverage",
    "test": "npm run test:unit && npm run test:component",
    "test:watch": "vitest --config vitest.config.main.ts",
    "preversion": "npm run typecheck && npm run lint && npm run test",
    "version": "echo \"Version bumped to $(node -p \"require('./package.json').version\")\"",
    "postversion": "echo \"Run 'git push origin main --follow-tags' to trigger the release workflow\""
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.3.1",
    "electron-store": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.2",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.1",
    "jsdom": "^26.1.0",
    "nock": "^14.0.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2",
    "wait-on": "^8.0.3"
  }
}
